from fastapi import FastAPI

app = FastAPI(
    title="Panterra AI Trading Platform",
    version="1.0.0",
    description="Production AI Trading Backend"
)


@app.get("/")
async def root():
    return {
        "status": "online",
        "message": "Welcome to Panterra AI Trading Platform",
        "version": "1.0.0"
    }


@app.get("/health")
async def health():
    return {
        "status": "healthy"
    }
